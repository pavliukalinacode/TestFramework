{
  "GlobalParameters": {
    "Logger": {
      "LoggerType": "#{LOGGERTYPE}#"
    },
    "WireMock": {
      "BaseUrl": "http://localhost:5003"
    },
    "Playwright": {
      "BrowserName": "chromium",
      "Headless": true,
      "SlowMoMs": 0,
      "ExpectTimeoutMs": 5000,
      "Tracing": {
        "Enabled": false,
        "Screenshots": false,
        "Snapshots": false,
        "Sources": false,
        "TraceNamePrefix": "trace",
        "OutputFolder": "artifacts/traces"
      }
    }
  },
  "Scenarios": {
    "PetTests": {
      "BaseUrl": "#{PETBASEURL}#",
      "Version": "#{PETVERSION}#",
      "Timeout": {
        "PostPet": "10"
      }
    },
    "SubscriptionTests": {
      "BaseUrl": "http://localhost:8082",
      "Version": "v1"
    },
    "EventsTests": {
      "BaseUrl": "http://localhost:8081",
      "Version": "v1"
    },
    "SauceDemoTests": {
      "BaseUrl": "https://www.saucedemo.com",
      "Users": [
        {
          "Type": "Standard",
          "ProfileName": "sauce-standard-user",
          "UserName": "standard_user",
          "Password": "secret_sauce",
          "SupportsSavedAuthState": true
        },
        {
          "Type": "Visual",
          "ProfileName": "sauce-visual-user",
          "UserName": "visual_user",
          "Password": "secret_sauce",
          "SupportsSavedAuthState": true
        }
      ]
    }
  }
}